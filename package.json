		"@fontsource/instrument-serif": "^5.2.8",
		"@libsql/client": "^0.17.2",
		"@nanogpt/mcp": "^1.1.6",
		"@types/node": "^25.6.0",
		"@typescript/native-preview": "^7.0.0-dev.20260411.1",
		"better-auth": "1.6.2",
		"cron-parser": "^5.5.0",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"epub2": "^3.0.2",
		"hastscript": "^9.0.1",
		"htmlparser2": "^12.0.0",
		"markdown-it-async": "^2.2.0",
		"pdf-parse": "^2.4.5",
		"svelte-sonner": "^1.1.0",
		"zod": "^4.3.6"
	}
