{
  "name": "nanochat",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:host": "vite dev --host",
    "build": "bun --bun ./node_modules/.bin/vite build",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:backfill-api-key-hashes": "bun run scripts/backfill-api-key-hashes.ts",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@iconify/json": "^2.2.476",
    "@playwright/test": "^1.60.0",
    "@shikijs/langs": "^4.1.0",
    "@shikijs/markdown-it": "^4.1.0",
    "@shikijs/themes": "^4.1.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "melt": "^0.44.0",
    "mode-watcher": "^1.1.0",
    "neverthrow": "^8.2.0",
    "openai": "^6.38.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "runed": "^0.37.1",
    "shiki": "^4.1.0",
    "svelte": "^5.55.9",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.4.8",
    "svelte-meta-tags": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ]
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "cookie": "^0.7.0"
  },
  "dependencies": {
    "@better-auth/passkey": "1.6.11",
    "@better-auth/sso": "1.6.11",
    "@floating-ui/dom": "^1.7.6",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "@fontsource-variable/open-sans": "^5.2.7",
    "@fontsource/instrument-serif": "^5.2.8",
    "@libsql/client": "^0.17.3",
    "@nanogpt/mcp": "^1.4.0",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260519.1",
    "better-auth": "1.6.11",
    "cron-parser": "^5.5.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "epub2": "^3.0.2",
    "hastscript": "^9.0.1",
    "htmlparser2": "^12.0.0",
    "markdown-it-async": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "svelte-sonner": "^1.1.1",
    "zod": "^4.4.3"
  },
  "resolutions": {
    "es-define-property": "npm:@socketregistry/es-define-property@^1",
    "function-bind": "npm:@socketregistry/function-bind@^1",
    "gopd": "npm:@socketregistry/gopd@^1",
    "has-symbols": "npm:@socketregistry/has-symbols@^1",
    "hasown": "npm:@socketregistry/hasown@^1",
    "indent-string": "npm:@socketregistry/indent-string@^1",
    "object-assign": "npm:@socketregistry/object-assign@^1",
    "safer-buffer": "npm:@socketregistry/safer-buffer@^1",
    "shell-quote": "npm:shell-quote@^1",
    "side-channel": "npm:@socketregistry/side-channel@^1"
  }
}
