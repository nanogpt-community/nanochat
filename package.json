{
	"name": "nanochat",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:host": "vite dev --host",
		"build": "bun --bun ./node_modules/.bin/vite build",
		"preview": "vite preview",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:backfill-api-key-hashes": "bun run scripts/backfill-api-key-hashes.ts",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@iconify/json": "^2.2.461",
		"@playwright/test": "^1.59.1",
		"@shikijs/langs": "^4.0.2",
		"@shikijs/markdown-it": "^4.0.2",
		"@shikijs/themes": "^4.0.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"concurrently": "^9.2.1",
		"dotenv": "^17.4.1",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"melt": "^0.44.0",
		"mode-watcher": "^1.1.0",
		"neverthrow": "^8.2.0",
		"openai": "^6.34.0",
		"prettier": "^3.8.2",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"runed": "^0.37.1",
		"shiki": "^4.0.2",
		"svelte": "^5.55.3",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.4.6",
		"svelte-meta-tags": "^4.6.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild"
		]
	},
	"overrides": {
		"@modelcontextprotocol/sdk": "^1.25.2",
		"cookie": "^0.7.0"
	},
	"dependencies": {
		"@better-auth/passkey": "1.6.2",
		"@floating-ui/dom": "^1.7.6",
		"@fontsource-variable/fraunces": "^5.2.9",
